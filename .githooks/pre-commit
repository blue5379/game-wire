#!/bin/sh
# history.json の JSON 整合性チェック
if git diff --cached --name-only | grep -q "src/content/history.json"; then
  echo "Validating src/content/history.json..."
  git show :src/content/history.json | jq empty 2>&1
  if [ $? -ne 0 ]; then
    echo "ERROR: src/content/history.json is invalid JSON. Fix before committing."
    exit 1
  fi
  echo "history.json is valid."
fi
