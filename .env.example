# YouTube Data API v3
# 取得先: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# IGDB API (Twitch Developer Portal)
# 取得先: https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# AWS Credentials (Amazon Bedrock用)
# IAMコンソールでアクセスキーを作成
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Tavily API (Web検索用)
# 取得先: https://tavily.com/
TAVILY_API_KEY=

# OpenCritic API (ゲームスコア取得用、任意)
# 取得先: developers@opencritic.com にメールで申請
OPENCRITIC_API_KEY=
