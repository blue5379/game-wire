  <script>
    /* ─── 1. 文字単位ヒーローアニメーション ─────────────────── */
    function splitChars(el, startDelay) {
      const text = el.textContent;
      el.textContent = '';
      [...text].forEach((char, i) => {
        const span = document.createElement('span');
        const delay = (startDelay + i * 0.045).toFixed(3);
        span.style.animationDelay = delay + 's';
        if (char === ' ' || char === '\u3000') {
          span.className = 'char char-space';
          span.textContent = '\u00a0';
        } else {
          span.className = 'char';
          span.textContent = char;
        }
        el.appendChild(span);
      });
      return startDelay + text.length * 0.045;
    }

    const line1 = document.querySelector('.hero-headline .line-1');
    const line2 = document.querySelector('.hero-headline .line-2');
    if (line1 && line2) {
      const nextDelay = splitChars(line1, 0.35);
      splitChars(line2, nextDelay + 0.08);
    }

    /* ─── 2. スクロール reveal (left / right / up) ───────────── */
    const allReveal = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');

    // グリッド内の子要素にスタガー delay を付与
    document.querySelectorAll('.features-grid, .content-grid, .platform-list').forEach(grid => {
      grid.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach((child, i) => {
        child.style.transitionDelay = `${i * 0.08}s`;
      });
    });

    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    allReveal.forEach(el => io.observe(el));

    /* ─── 3. CTA ghost text パララックス ─────────────────────── */
    const ctaBg = document.getElementById('ctaBgText');
    if (ctaBg) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const ctaSection = ctaBg.closest('.cta-section');
            if (ctaSection) {
              const rect = ctaSection.getBoundingClientRect();
              const progress = -rect.top / (window.innerHeight + rect.height);
              ctaBg.style.transform = `translateX(-50%) translateY(${progress * 60}px)`;
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }
  </script>

