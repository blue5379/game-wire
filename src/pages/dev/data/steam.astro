---
/**
 * 開発用データビューアー - Steam データ
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import * as fs from 'node:fs';
import * as path from 'node:path';

const dataDir = path.join(process.cwd(), 'data');
let steamData: any = null;
let error: string | null = null;

try {
  const aggregatedPath = path.join(dataDir, 'aggregated.json');
  if (fs.existsSync(aggregatedPath)) {
    const data = JSON.parse(fs.readFileSync(aggregatedPath, 'utf-8'));
    steamData = data.steamData;
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'データ読み込みエラー';
}
---

<BaseLayout title="Steam Data - Data Viewer">
  <div class="dev-container">
    <header class="dev-header">
      <span class="dev-badge">DEV</span>
      <h1>Steam データ</h1>
      <a href="/dev/data" class="back-link">← ダッシュボード</a>
    </header>

    {error && (
      <div class="error-box">
        <strong>エラー:</strong> {error}
      </div>
    )}

    {steamData && (
      <>
        <p class="fetched-at">取得日時: {new Date(steamData.fetchedAt).toLocaleString('ja-JP')}</p>

        <div class="data-sections">
          <section class="data-section">
            <h2>Top Sellers ({steamData.topSellers?.length || 0})</h2>
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr>
                    <th>#</th>
                    <th>タイトル</th>
                    <th>App ID</th>
                    <th>価格</th>
                    <th>割引</th>
                  </tr>
                </thead>
                <tbody>
                  {steamData.topSellers?.map((game: any, i: number) => (
                    <tr>
                      <td class="rank">{i + 1}</td>
                      <td class="title">
                        <a href={`https://store.steampowered.com/app/${game.appId}`} target="_blank" rel="noopener">
                          {game.name}
                        </a>
                      </td>
                      <td class="app-id">{game.appId}</td>
                      <td>{game.priceFormatted || '-'}</td>
                      <td class={game.discount ? 'discount' : ''}>
                        {game.discount ? `-${game.discount}%` : '-'}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <section class="data-section">
            <h2>Top Played ({steamData.topPlayed?.length || 0})</h2>
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr>
                    <th>#</th>
                    <th>タイトル</th>
                    <th>App ID</th>
                    <th>現在プレイヤー数</th>
                    <th>ピーク</th>
                  </tr>
                </thead>
                <tbody>
                  {steamData.topPlayed?.map((game: any, i: number) => (
                    <tr>
                      <td class="rank">{i + 1}</td>
                      <td class="title">
                        <a href={`https://store.steampowered.com/app/${game.appId}`} target="_blank" rel="noopener">
                          {game.name}
                        </a>
                      </td>
                      <td class="app-id">{game.appId}</td>
                      <td class="players">{game.currentPlayers?.toLocaleString() || '-'}</td>
                      <td class="players">{game.peakPlayers?.toLocaleString() || '-'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        </div>
      </>
    )}

    {!steamData && !error && (
      <div class="no-data">
        <p>Steamデータがありません。</p>
        <code>npm run fetch-data</code> を実行してください。
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .dev-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .dev-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #333;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .dev-badge {
    background: #f59e0b;
    color: #000;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
  }

  .dev-header h1 {
    margin: 0;
    flex: 1;
  }

  .back-link {
    font-size: 0.875rem;
  }

  .error-box {
    background: #7f1d1d;
    border: 1px solid #dc2626;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .fetched-at {
    color: #888;
    font-size: 0.875rem;
    margin-bottom: 2rem;
  }

  .data-sections {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .data-section h2 {
    margin-bottom: 1rem;
    color: #d64550;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  th, td {
    padding: 0.75rem;
    text-align: left;
    border-bottom: 1px solid #333;
  }

  th {
    background: #1a1a1a;
    color: #888;
    font-weight: 500;
    position: sticky;
    top: 0;
  }

  tr:hover {
    background: #1a1a1a;
  }

  .rank {
    width: 40px;
    color: #888;
  }

  .title {
    max-width: 400px;
  }

  .title a {
    color: inherit;
  }

  .title a:hover {
    color: #d64550;
  }

  .app-id {
    font-family: monospace;
    color: #888;
  }

  .players {
    font-family: monospace;
    color: #22c55e;
  }

  .discount {
    color: #22c55e;
    font-weight: bold;
  }

  .no-data {
    text-align: center;
    padding: 4rem;
    color: #888;
  }

  .no-data code {
    display: block;
    margin-top: 1rem;
    background: #1a1a1a;
    padding: 0.5rem 1rem;
    border-radius: 4px;
  }
</style>
