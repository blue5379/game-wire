---
/**
 * 開発用データビューアー - ダッシュボード
 * fetch-dataで取得した情報を確認するための開発専用ページ
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import * as fs from 'node:fs';
import * as path from 'node:path';

// データ読み込み
const dataDir = path.join(process.cwd(), 'data');
let aggregatedData: any = null;
let selectedGames: any = null;
let error: string | null = null;

try {
  const aggregatedPath = path.join(dataDir, 'aggregated.json');
  const selectedPath = path.join(dataDir, 'selected-games.json');

  if (fs.existsSync(aggregatedPath)) {
    aggregatedData = JSON.parse(fs.readFileSync(aggregatedPath, 'utf-8'));
  }
  if (fs.existsSync(selectedPath)) {
    selectedGames = JSON.parse(fs.readFileSync(selectedPath, 'utf-8'));
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'データ読み込みエラー';
}

// 統計情報
const stats = aggregatedData ? {
  totalGames: aggregatedData.games?.length || 0,
  steamSellers: aggregatedData.steamData?.topSellers?.length || 0,
  steamPlayed: aggregatedData.steamData?.topPlayed?.length || 0,
  youtubeVideos: aggregatedData.youtubeData?.trendingVideos?.length || 0,
  igdbGames: aggregatedData.igdbData?.games?.length || 0,
  metacriticScores: aggregatedData.metacriticData?.scores?.length || 0,
  fetchedAt: aggregatedData.fetchedAt,
} : null;

// 選定結果
const selection = selectedGames ? {
  newReleases: selectedGames.newReleases || [],
  indies: selectedGames.indies || [],
  featured: selectedGames.featured,
  classic: selectedGames.classic,
} : null;

// データ品質チェック
const warnings: string[] = [];
if (selection) {
  for (const game of [...selection.newReleases, ...selection.indies]) {
    if (!game.coverImage) warnings.push(`カバー画像なし: ${game.title}`);
    if (!game.genres || game.genres.length === 0) warnings.push(`ジャンルなし: ${game.title}`);
    if (game.title.length < 3) warnings.push(`タイトル不正: ${game.title}`);
  }
}
---

<BaseLayout title="Data Viewer">
  <div class="dev-container">
    <header class="dev-header">
      <span class="dev-badge">DEV</span>
      <h1>Data Viewer</h1>
      <p class="dev-description">fetch-dataで取得した情報を確認</p>
    </header>

    {error && (
      <div class="error-box">
        <strong>エラー:</strong> {error}
      </div>
    )}

    {stats && (
      <section class="stats-section">
        <h2>データ取得状況</h2>
        <p class="fetched-at">取得日時: {new Date(stats.fetchedAt).toLocaleString('ja-JP')}</p>

        <div class="stats-grid">
          <a href="/dev/data/steam" class="stat-card">
            <div class="stat-value">{stats.steamSellers}</div>
            <div class="stat-label">Steam Top Sellers</div>
          </a>
          <a href="/dev/data/steam" class="stat-card">
            <div class="stat-value">{stats.steamPlayed}</div>
            <div class="stat-label">Steam Top Played</div>
          </a>
          <a href="/dev/data/youtube" class="stat-card">
            <div class="stat-value">{stats.youtubeVideos}</div>
            <div class="stat-label">YouTube Videos</div>
          </a>
          <div class="stat-card">
            <div class="stat-value">{stats.igdbGames}</div>
            <div class="stat-label">IGDB Games</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">{stats.metacriticScores}</div>
            <div class="stat-label">Metacritic Scores</div>
          </div>
          <div class="stat-card highlight">
            <div class="stat-value">{stats.totalGames}</div>
            <div class="stat-label">統合ゲーム数</div>
          </div>
        </div>
      </section>
    )}

    {warnings.length > 0 && (
      <section class="warnings-section">
        <h2>データ品質警告</h2>
        <ul class="warning-list">
          {warnings.map(w => <li>{w}</li>)}
        </ul>
      </section>
    )}

    {selection && (
      <section class="selection-section">
        <h2>記事用選定結果</h2>
        <a href="/dev/data/selected" class="view-detail-link">詳細を見る →</a>

        <div class="selection-grid">
          <div class="selection-category">
            <h3>新作紹介 ({selection.newReleases.length}本)</h3>
            {selection.newReleases.map((game: any) => (
              <div class="game-card">
                {game.coverImage && <img src={game.coverImage} alt={game.title} />}
                <div class="game-info">
                  <div class="game-title">{game.title}</div>
                  <div class="game-meta">
                    {game.developer && <span>{game.developer}</span>}
                    {game.metascore && <span class="score">Score: {game.metascore}</span>}
                  </div>
                  <div class="game-sources">
                    {game.source?.map((s: string) => <span class="source-tag">{s}</span>)}
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="selection-category">
            <h3>インディー ({selection.indies.length}本)</h3>
            {selection.indies.map((game: any) => (
              <div class="game-card">
                {game.coverImage && <img src={game.coverImage} alt={game.title} />}
                <div class="game-info">
                  <div class="game-title">{game.title}</div>
                  <div class="game-meta">
                    {game.developer && <span>{game.developer}</span>}
                  </div>
                  <div class="game-sources">
                    {game.source?.map((s: string) => <span class="source-tag">{s}</span>)}
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="selection-category">
            <h3>特集</h3>
            {selection.featured ? (
              <div class="game-card">
                {selection.featured.coverImage && <img src={selection.featured.coverImage} alt={selection.featured.title} />}
                <div class="game-info">
                  <div class="game-title">{selection.featured.title}</div>
                </div>
              </div>
            ) : <p class="no-data">選定なし</p>}
          </div>

          <div class="selection-category">
            <h3>名作深掘り</h3>
            {selection.classic ? (
              <div class="game-card">
                {selection.classic.coverImage && <img src={selection.classic.coverImage} alt={selection.classic.title} />}
                <div class="game-info">
                  <div class="game-title">{selection.classic.title}</div>
                  {selection.classic.metascore && <span class="score">Score: {selection.classic.metascore}</span>}
                </div>
              </div>
            ) : <p class="no-data">選定なし</p>}
          </div>
        </div>
      </section>
    )}

    <nav class="dev-nav">
      <a href="/dev/data/steam">Steam データ</a>
      <a href="/dev/data/youtube">YouTube データ</a>
      <a href="/dev/data/selected">選定結果詳細</a>
      <a href="/">← サイトに戻る</a>
    </nav>
  </div>
</BaseLayout>

<style>
  .dev-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .dev-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #333;
  }

  .dev-badge {
    display: inline-block;
    background: #f59e0b;
    color: #000;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .dev-header h1 {
    margin: 0.5rem 0;
  }

  .dev-description {
    color: #888;
    margin: 0;
  }

  .error-box {
    background: #7f1d1d;
    border: 1px solid #dc2626;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .stats-section, .selection-section, .warnings-section {
    margin-bottom: 3rem;
  }

  .fetched-at {
    color: #888;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
  }

  .stat-card {
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .stat-card:hover {
    border-color: #d64550;
  }

  .stat-card.highlight {
    border-color: #d64550;
    background: #1f1a1a;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: bold;
    color: #d64550;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #888;
    margin-top: 0.5rem;
  }

  .warnings-section {
    background: #422006;
    border: 1px solid #f59e0b;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .warnings-section h2 {
    color: #f59e0b;
    margin-top: 0;
  }

  .warning-list {
    margin: 0;
    padding-left: 1.5rem;
  }

  .warning-list li {
    margin-bottom: 0.5rem;
    color: #fcd34d;
  }

  .view-detail-link {
    float: right;
    font-size: 0.875rem;
  }

  .selection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .selection-category {
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 1rem;
  }

  .selection-category h3 {
    margin: 0 0 1rem;
    font-size: 1rem;
    color: #888;
    border-bottom: 1px solid #333;
    padding-bottom: 0.5rem;
  }

  .game-card {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .game-card img {
    width: 60px;
    height: 80px;
    object-fit: cover;
    border-radius: 4px;
  }

  .game-info {
    flex: 1;
    min-width: 0;
  }

  .game-title {
    font-weight: bold;
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .game-meta {
    font-size: 0.75rem;
    color: #888;
  }

  .game-meta .score {
    color: #22c55e;
    margin-left: 0.5rem;
  }

  .game-sources {
    margin-top: 0.5rem;
  }

  .source-tag {
    display: inline-block;
    background: #333;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-size: 0.625rem;
    margin-right: 0.25rem;
    text-transform: uppercase;
  }

  .no-data {
    color: #666;
    font-style: italic;
  }

  .dev-nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid #333;
  }

  .dev-nav a {
    background: #1a1a1a;
    border: 1px solid #333;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: border-color 0.2s;
  }

  .dev-nav a:hover {
    border-color: #d64550;
  }
</style>
