---
/**
 * 開発用データビューアー - 選定結果詳細
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import * as fs from 'node:fs';
import * as path from 'node:path';

const dataDir = path.join(process.cwd(), 'data');
let selectedGames: any = null;
let error: string | null = null;

try {
  const selectedPath = path.join(dataDir, 'selected-games.json');
  if (fs.existsSync(selectedPath)) {
    selectedGames = JSON.parse(fs.readFileSync(selectedPath, 'utf-8'));
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'データ読み込みエラー';
}

// すべての選定ゲームをフラット化
const allGames = selectedGames ? [
  ...selectedGames.newReleases.map((g: any) => ({ ...g, category: '新作紹介' })),
  ...selectedGames.indies.map((g: any) => ({ ...g, category: 'インディー' })),
  ...(selectedGames.featured ? [{ ...selectedGames.featured, category: '特集' }] : []),
  ...(selectedGames.classic ? [{ ...selectedGames.classic, category: '名作深掘り' }] : []),
] : [];
---

<BaseLayout title="Selected Games - Data Viewer">
  <div class="dev-container">
    <header class="dev-header">
      <span class="dev-badge">DEV</span>
      <h1>選定結果詳細</h1>
      <a href="/dev/data" class="back-link">← ダッシュボード</a>
    </header>

    {error && (
      <div class="error-box">
        <strong>エラー:</strong> {error}
      </div>
    )}

    {selectedGames && (
      <div class="games-list">
        {allGames.map((game: any, index: number) => (
          <article class="game-detail">
            <div class="game-header">
              <span class={`category-badge category-${game.category.replace(/[^a-zA-Z]/g, '')}`}>
                {game.category}
              </span>
              <h2>{game.title}</h2>
            </div>

            <div class="game-content">
              <div class="game-images">
                {game.coverImage ? (
                  <img src={game.coverImage} alt={game.title} class="cover-image" />
                ) : (
                  <div class="no-cover">No Cover</div>
                )}
                {game.screenshots && game.screenshots.length > 0 && (
                  <div class="screenshots">
                    {game.screenshots.slice(0, 3).map((url: string) => (
                      <img src={url} alt="Screenshot" class="screenshot" />
                    ))}
                  </div>
                )}
              </div>

              <div class="game-data">
                <table class="data-table">
                  <tbody>
                    <tr>
                      <th>正規化タイトル</th>
                      <td><code>{game.normalizedTitle}</code></td>
                    </tr>
                    <tr>
                      <th>ジャンル</th>
                      <td>
                        {game.genres?.length > 0
                          ? game.genres.join(', ')
                          : <span class="warning">未設定</span>}
                      </td>
                    </tr>
                    <tr>
                      <th>プラットフォーム</th>
                      <td>
                        {game.platforms?.length > 0
                          ? game.platforms.join(', ')
                          : <span class="warning">未設定</span>}
                      </td>
                    </tr>
                    <tr>
                      <th>発売日</th>
                      <td>{game.releaseDate || <span class="muted">不明</span>}</td>
                    </tr>
                    <tr>
                      <th>開発</th>
                      <td>{game.developer || <span class="muted">不明</span>}</td>
                    </tr>
                    <tr>
                      <th>パブリッシャー</th>
                      <td>{game.publisher || <span class="muted">不明</span>}</td>
                    </tr>
                    <tr>
                      <th>開発国</th>
                      <td>{game.developerCountry || <span class="muted">不明</span>}</td>
                    </tr>
                    <tr>
                      <th>Metascore</th>
                      <td>
                        {game.metascore
                          ? <span class="score">{game.metascore}</span>
                          : <span class="muted">なし</span>}
                      </td>
                    </tr>
                    <tr>
                      <th>User Score</th>
                      <td>
                        {game.userScore
                          ? <span class="score">{game.userScore}</span>
                          : <span class="muted">なし</span>}
                      </td>
                    </tr>
                    <tr>
                      <th>Steam Rank</th>
                      <td>{game.steamRank || <span class="muted">-</span>}</td>
                    </tr>
                    <tr>
                      <th>Steam Players</th>
                      <td>{game.steamPlayers?.toLocaleString() || <span class="muted">-</span>}</td>
                    </tr>
                    <tr>
                      <th>YouTube人気度</th>
                      <td>
                        {game.youtubePopularity
                          ? `${(game.youtubePopularity / 1000000).toFixed(2)}M views`
                          : <span class="muted">-</span>}
                      </td>
                    </tr>
                    <tr>
                      <th>データソース</th>
                      <td>
                        <div class="source-tags">
                          {game.source?.map((s: string) => (
                            <span class="source-tag">{s}</span>
                          ))}
                        </div>
                      </td>
                    </tr>
                    {game.isAiInferred && (
                      <tr>
                        <th>AI推測</th>
                        <td class="ai-inferred">
                          {game.aiInferredFields?.join(', ')}
                        </td>
                      </tr>
                    )}
                  </tbody>
                </table>

                {game.sourceUrls && (
                  <div class="source-links">
                    <h4>参照元リンク</h4>
                    <div class="links">
                      {game.sourceUrls.steam && (
                        <a href={game.sourceUrls.steam} target="_blank" rel="noopener">Steam</a>
                      )}
                      {game.sourceUrls.igdb && (
                        <a href={game.sourceUrls.igdb} target="_blank" rel="noopener">IGDB</a>
                      )}
                      {game.sourceUrls.metacritic && (
                        <a href={game.sourceUrls.metacritic} target="_blank" rel="noopener">Metacritic</a>
                      )}
                      {game.sourceUrls.youtube && game.sourceUrls.youtube[0] && (
                        <a href={game.sourceUrls.youtube[0]} target="_blank" rel="noopener">YouTube</a>
                      )}
                    </div>
                  </div>
                )}

                {game.summary && (
                  <div class="summary">
                    <h4>概要</h4>
                    <p>{game.summary}</p>
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}

    {!selectedGames && !error && (
      <div class="no-data">
        <p>選定データがありません。</p>
        <code>npm run fetch-data</code> を実行してください。
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .dev-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .dev-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #333;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .dev-badge {
    background: #f59e0b;
    color: #000;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
  }

  .dev-header h1 {
    margin: 0;
    flex: 1;
  }

  .back-link {
    font-size: 0.875rem;
  }

  .error-box {
    background: #7f1d1d;
    border: 1px solid #dc2626;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .games-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .game-detail {
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 12px;
    overflow: hidden;
  }

  .game-header {
    padding: 1.5rem;
    border-bottom: 1px solid #333;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .category-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
  }

  .category-badge.category-新作紹介 { background: #3b82f6; }
  .category-badge.category-インディー { background: #8b5cf6; }
  .category-badge.category-特集 { background: #f59e0b; color: #000; }
  .category-badge.category-名作深掘り { background: #22c55e; }

  .game-header h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .game-content {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 2rem;
    padding: 1.5rem;
  }

  @media (max-width: 768px) {
    .game-content {
      grid-template-columns: 1fr;
    }
  }

  .game-images {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cover-image {
    width: 100%;
    border-radius: 8px;
  }

  .no-cover {
    width: 100%;
    aspect-ratio: 3 / 4;
    background: #333;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
    border-radius: 8px;
  }

  .screenshots {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .screenshot {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 4px;
  }

  .game-data {
    min-width: 0;
  }

  .data-table {
    width: 100%;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .data-table th {
    text-align: left;
    padding: 0.5rem;
    color: #888;
    font-weight: 500;
    width: 140px;
    vertical-align: top;
  }

  .data-table td {
    padding: 0.5rem;
  }

  .data-table code {
    background: #333;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
  }

  .warning {
    color: #f59e0b;
  }

  .muted {
    color: #666;
  }

  .score {
    color: #22c55e;
    font-weight: bold;
  }

  .source-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .source-tag {
    background: #333;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    text-transform: uppercase;
  }

  .ai-inferred {
    color: #8b5cf6;
    font-style: italic;
  }

  .source-links {
    margin-bottom: 1.5rem;
  }

  .source-links h4 {
    font-size: 0.875rem;
    color: #888;
    margin-bottom: 0.5rem;
  }

  .links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .links a {
    background: #333;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .links a:hover {
    background: #444;
  }

  .summary h4 {
    font-size: 0.875rem;
    color: #888;
    margin-bottom: 0.5rem;
  }

  .summary p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #ccc;
  }

  .no-data {
    text-align: center;
    padding: 4rem;
    color: #888;
  }

  .no-data code {
    display: block;
    margin-top: 1rem;
    background: #1a1a1a;
    padding: 0.5rem 1rem;
    border-radius: 4px;
  }
</style>
