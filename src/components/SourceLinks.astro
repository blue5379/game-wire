---
/**
 * 参考リンク表示コンポーネント
 * 記事の情報ソースへのリンクを表示
 */

import type { StorePlatform, StoreLink } from '../../scripts/types';

interface Props {
  sourceUrls?: {
    steam?: string;
    igdb?: string;
    metacritic?: string;
    official?: string;
    officialUrlSource?: string;
    stores?: StoreLink[];
  };
}

const { sourceUrls } = Astro.props;

const STORE_META: Record<StorePlatform, { icon: string; label: string; hoverColor: string }> = {
  steam:       { icon: '🎮', label: 'Steamストアページ',        hoverColor: '#1b2838' },
  nintendo:    { icon: '🔴', label: 'Nintendo Switch eShop', hoverColor: '#e4000f' },
  playstation: { icon: '🔵', label: 'PlayStation Store',      hoverColor: '#003087' },
  xbox:        { icon: '🟢', label: 'Xbox Store',              hoverColor: '#107c10' },
  appstore:    { icon: '📱', label: 'App Store (iOS)',         hoverColor: '#0071e3' },
  googleplay:  { icon: '▶️',  label: 'Google Play',            hoverColor: '#01875f' },
  epicgames:   { icon: '⚫', label: 'Epic Games Store',        hoverColor: '#2f2f2f' },
  gog:         { icon: '🌌', label: 'GOG',                     hoverColor: '#86328a' },
};

// 旧 steam フィールドを stores[] に変換する互換シム
const normalizedStores: StoreLink[] = sourceUrls?.stores
  ? [...sourceUrls.stores]
  : [];

if (
  sourceUrls?.steam &&
  !normalizedStores.some((s) => s.platform === 'steam')
) {
  normalizedStores.unshift({
    platform: 'steam',
    url: sourceUrls.steam,
    resolvedBy: 'cache',
    confidence: 'high',
  });
}

const hasLinks =
  sourceUrls &&
  (sourceUrls.official ||
    normalizedStores.length > 0 ||
    sourceUrls.igdb ||
    sourceUrls.metacritic);
---

{hasLinks && (
  <section class="source-links">
    <h3>🔗 参考リンク</h3>
    <ul class="links-list">
      {sourceUrls.official && (
        <li>
          <a href={sourceUrls.official} target="_blank" rel="noopener noreferrer" class="link-item official">
            <span class="icon">🌐</span>
            <span class="text">公式サイト</span>
            <span class="external-icon">↗</span>
          </a>
        </li>
      )}
      {normalizedStores.map((store) => {
        const meta = STORE_META[store.platform];
        if (!meta) return null;
        return (
          <li>
            <a
              href={store.url}
              target="_blank"
              rel="noopener noreferrer"
              class={`link-item store store-${store.platform}`}
              style={`--store-hover: ${meta.hoverColor}`}
            >
              <span class="icon">{meta.icon}</span>
              <span class="text">{meta.label}</span>
              <span class="external-icon">↗</span>
            </a>
          </li>
        );
      })}
      {sourceUrls.igdb && (
        <li>
          <a href={sourceUrls.igdb} target="_blank" rel="noopener noreferrer" class="link-item igdb">
            <span class="icon">📚</span>
            <span class="text">IGDB（ゲームデータベース）</span>
            <span class="external-icon">↗</span>
          </a>
        </li>
      )}
      {sourceUrls.metacritic && (
        <li>
          <a href={sourceUrls.metacritic} target="_blank" rel="noopener noreferrer" class="link-item metacritic">
            <span class="icon">⭐</span>
            <span class="text">OpenCritic（レビュー）</span>
            <span class="external-icon">↗</span>
          </a>
        </li>
      )}
    </ul>
  </section>
)}

<style>
  .source-links {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    margin-top: var(--spacing-lg);
    border: 1px solid var(--color-border);
  }

  .source-links h3 {
    font-size: 1rem;
    color: var(--color-text);
    margin: 0 0 var(--spacing-sm) 0;
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--color-border);
  }

  .links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .link-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-text);
    transition: background-color 0.2s ease, transform 0.2s ease;
    font-size: 0.9rem;
  }

  .link-item:hover {
    background: var(--color-background);
    transform: translateX(4px);
  }

  .link-item .icon {
    flex-shrink: 0;
  }

  .link-item .text {
    flex-grow: 1;
  }

  .link-item .external-icon {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .link-item.official:hover {
    color: #006aff;
  }

  .link-item.store:hover {
    color: var(--store-hover);
  }

  .link-item.igdb:hover {
    color: #9147ff;
  }

  .link-item.metacritic:hover {
    color: #ffcc33;
  }

  @media (max-width: 768px) {
    .source-links {
      padding: var(--spacing-sm);
    }

    .link-item {
      font-size: 0.85rem;
    }
  }
</style>
