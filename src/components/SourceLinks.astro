---
/**
 * 参考リンク表示コンポーネント
 * 記事の情報ソースへのリンクを表示
 */

interface Props {
  sourceUrls?: {
    steam?: string;
    igdb?: string;
    metacritic?: string;
    official?: string;
  };
}

const { sourceUrls } = Astro.props;

// リンクがない場合は何も表示しない
const hasLinks = sourceUrls && (
  sourceUrls.official ||
  sourceUrls.steam ||
  sourceUrls.igdb ||
  sourceUrls.metacritic
);
---

{hasLinks && (
  <section class="source-links">
    <h3>🔗 参考リンク</h3>
    <ul class="links-list">
      {sourceUrls.official && (
        <li>
          <a href={sourceUrls.official} target="_blank" rel="noopener noreferrer" class="link-item official">
            <span class="icon">🌐</span>
            <span class="text">公式サイト（日本語）</span>
            <span class="external-icon">↗</span>
          </a>
        </li>
      )}
      {sourceUrls.steam && (
        <li>
          <a href={sourceUrls.steam} target="_blank" rel="noopener noreferrer" class="link-item steam">
            <span class="icon">🎮</span>
            <span class="text">Steamストアページ</span>
            <span class="external-icon">↗</span>
          </a>
        </li>
      )}
      {sourceUrls.igdb && (
        <li>
          <a href={sourceUrls.igdb} target="_blank" rel="noopener noreferrer" class="link-item igdb">
            <span class="icon">📚</span>
            <span class="text">IGDB（ゲームデータベース）</span>
            <span class="external-icon">↗</span>
          </a>
        </li>
      )}
      {sourceUrls.metacritic && (
        <li>
          <a href={sourceUrls.metacritic} target="_blank" rel="noopener noreferrer" class="link-item metacritic">
            <span class="icon">⭐</span>
            <span class="text">OpenCritic（レビュー）</span>
            <span class="external-icon">↗</span>
          </a>
        </li>
      )}
    </ul>
  </section>
)}

<style>
  .source-links {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    margin-top: var(--spacing-lg);
    border: 1px solid var(--color-border);
  }

  .source-links h3 {
    font-size: 1rem;
    color: var(--color-text);
    margin: 0 0 var(--spacing-sm) 0;
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--color-border);
  }

  .links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .link-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-text);
    transition: background-color 0.2s ease, transform 0.2s ease;
    font-size: 0.9rem;
  }

  .link-item:hover {
    background: var(--color-background);
    transform: translateX(4px);
  }

  .link-item .icon {
    flex-shrink: 0;
  }

  .link-item .text {
    flex-grow: 1;
  }

  .link-item .external-icon {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .link-item.official:hover {
    color: #006aff;
  }

  .link-item.steam:hover {
    color: #1b2838;
  }

  .link-item.igdb:hover {
    color: #9147ff;
  }

  .link-item.metacritic:hover {
    color: #ffcc33;
  }


  @media (max-width: 768px) {
    .source-links {
      padding: var(--spacing-sm);
    }

    .link-item {
      font-size: 0.85rem;
    }
  }
</style>
